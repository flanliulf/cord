{
  "name": "@fancyliu/cord",
  "version": "0.1.3",
  "description": "Document relationship graph engine for AI-assisted development",
  "type": "module",
  "types": "./dist/index.d.ts",
  "bin": {
    "cord": "dist/cli/index.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/flanliulf/cord.git"
  },
  "homepage": "https://github.com/flanliulf/cord#readme",
  "bugs": {
    "url": "https://github.com/flanliulf/cord/issues"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.zh.md",
    "docs/*.md"
  ],
  "scripts": {
    "build": "tsup",
    "prepack": "npm run build",
    "pack:check": "npm pack --dry-run",
    "release:check": "npm run lint && npm run type-check && npm test && npm run build && npm run pack:check",
    "smoke:bin": "node dist/cli/index.js --version",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "type-check": "tsc --noEmit -p tsconfig.check.json"
  },
  "dependencies": {
    "@clack/prompts": "^1.2.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "better-sqlite3": "^12.8.0",
    "chalk": "^5.4.1",
    "commander": "^14.0.3",
    "gray-matter": "^4.0.3",
    "remark-frontmatter": "^5.0.0",
    "remark-gfm": "^4.0.1",
    "remark-parse": "^11.0.0",
    "unified": "^11.0.5",
    "zod": "^3.24.2",
    "zod-to-json-schema": "^3.25.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20.19.39",
    "@vitest/coverage-v8": "^4.1.5",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.1",
    "semantic-release": "^25.0.3",
    "tsup": "^8.5.1",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.58.1",
    "vitest": "^4.1.3"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT"
}
